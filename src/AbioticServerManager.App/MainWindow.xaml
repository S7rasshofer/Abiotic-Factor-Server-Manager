<Window x:Class="AbioticServerManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AbioticServerManager.App"
        xmlns:vm="clr-namespace:AbioticServerManager.App.ViewModels"
        xmlns:conv="clr-namespace:AbioticServerManager.App.Converters"
        xmlns:behaviors="clr-namespace:AbioticServerManager.App.Behaviors"
        xmlns:diag="clr-namespace:AbioticServerManager.Core.Diagnostics;assembly=AbioticServerManager.Core"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="Facility Overseer v1.1.0"
        Height="780" Width="1180"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI"
        FontSize="13">

    <Window.Resources>
        <conv:SeverityToBrushConverter x:Key="SeverityToBrush" />
        <conv:RunningToBrushConverter x:Key="RunningToBrush" />
        <conv:HealthToBrushConverter x:Key="HealthToBrush" />
        <conv:CategoryIconConverter x:Key="CategoryIcon" />
        <conv:InverseBoolConverter x:Key="InverseBool" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <conv:StringToVisibilityConverter x:Key="StringToVisibility" />
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVisibility" />
        <conv:CheckStatusToBrushConverter x:Key="CheckStatusToBrush" />
        <conv:NetworkCheckStatusToBrushConverter x:Key="NetworkCheckStatusToBrush" />
        <conv:NetworkVerdictStatusToBrushConverter x:Key="NetworkVerdictStatusToBrush" />
        <conv:PositiveIntToVisibilityConverter x:Key="PositiveIntToVisibility" />
        <conv:IntegritySeverityToBrushConverter x:Key="IntegritySeverityToBrush" />
        <conv:RecommendedPriorityToBrushConverter x:Key="RecommendedPriorityToBrush" />
        <conv:BackupEntryToConfidenceConverter x:Key="BackupConfidence" />
        <conv:StartupPhaseStatusToBrushConverter x:Key="StartupPhaseStatusToBrush" />
        <conv:IsAdminToBrushConverter x:Key="IsAdminToBrush"
                                      AdminBrush="{StaticResource AdminAccentBrush}"
                                      DefaultBrush="{StaticResource TextBrush}" />

        <!-- Shared Save bar for every sandbox tab. Content = ServerInstanceViewModel.
             The sandbox auto-loads on world selection, so there is no Load button. -->
        <DataTemplate x:Key="SandboxToolbar">
            <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="4"
                    Padding="10,8" Margin="16,16,16,0">
                <DockPanel LastChildFill="False">
                    <Button DockPanel.Dock="Left" Content="Save Sandbox"
                            Style="{StaticResource AccentButton}"
                            Command="{Binding DataContext.SaveSandboxCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                    <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource WarnBrush}"
                               FontWeight="SemiBold" VerticalAlignment="Center"
                               Text="* unsaved changes"
                               Visibility="{Binding Sandbox.IsDirty, Converter={StaticResource BoolToVisibility}}" />
                    <TextBlock VerticalAlignment="Center" Margin="14,0,0,0"
                               Style="{StaticResource MutedText}"
                               Text="{Binding Sandbox.StatusText}" />
                </DockPanel>
            </Border>
        </DataTemplate>

        <!-- UI Tweaks A2/A3: the title-card world-action cluster. Collapsed by
             default (MaxWidth 0); slides open/closed with AreWorldActionsExpanded. -->
        <Style x:Key="WorldActionsClusterStyle" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="ClipToBounds" Value="True" />
            <Setter Property="MaxWidth" Value="0" />
            <Setter Property="Opacity" Value="0" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding AreWorldActionsExpanded}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="MaxWidth"
                                                 To="640" Duration="0:0:0.22" />
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="1" Duration="0:0:0.22" />
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="MaxWidth"
                                                 To="0" Duration="0:0:0.18" />
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="0" Duration="0:0:0.18" />
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <!-- D12: right-click moderation menu on a roster row. The menu lives on
             the ListBoxItem; PlacementTarget.Tag carries the MainViewModel and
             PlacementTarget.DataContext the right-clicked RosterRowViewModel. -->
        <Style x:Key="RosterRowStyle" TargetType="{x:Type ListBoxItem}"
               BasedOn="{StaticResource {x:Type ListBoxItem}}">
            <Setter Property="Tag"
                    Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />
            <Setter Property="ContextMenu">
                <Setter.Value>
                    <ContextMenu Background="{StaticResource SurfaceRaisedBrush}">
                        <MenuItem Visibility="{Binding IsAdmin, Converter={StaticResource InvBoolToVisibility}}"
                                  Command="{Binding PlacementTarget.Tag.PromotePlayerCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
                            <MenuItem.Header>
                                <TextBlock Text="Promote to moderator" Foreground="{StaticResource TextBrush}" />
                            </MenuItem.Header>
                        </MenuItem>
                        <MenuItem Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibility}}"
                                  Command="{Binding PlacementTarget.Tag.DemotePlayerCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
                            <MenuItem.Header>
                                <TextBlock Text="Demote (remove moderator)" Foreground="{StaticResource TextBrush}" />
                            </MenuItem.Header>
                        </MenuItem>
                        <Separator />
                        <MenuItem Command="{Binding PlacementTarget.Tag.BanPlayerCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
                            <MenuItem.Header>
                                <TextBlock Text="Ban player" Foreground="{StaticResource TextBrush}" />
                            </MenuItem.Header>
                        </MenuItem>
                    </ContextMenu>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BackgroundBrush}" Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}"
                BorderBrush="{StaticResource BorderMutedBrush}"
                BorderThickness="1" CornerRadius="6"
                Padding="10" Margin="0,0,0,12">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="0,0,24,0">
                    <Border Background="{StaticResource AccentBrush}"
                            CornerRadius="3" Padding="7,3"
                            VerticalAlignment="Center" Margin="0,0,8,0">
                        <TextBlock Text="GATE" Foreground="{StaticResource AccentTextBrush}"
                                   FontSize="11" FontWeight="Bold" />
                    </Border>
                    <StackPanel>
                        <!-- UI Tweaks A4: clicking the title toggles the world-action
                             cluster (Create / Clone / Delete / Save). -->
                        <StackPanel Orientation="Horizontal" Background="Transparent"
                                    Cursor="Hand"
                                    ToolTip="Show or hide the world action buttons (Create, Clone, Delete, Save).">
                            <StackPanel.InputBindings>
                                <MouseBinding Gesture="LeftClick"
                                              Command="{Binding ToggleWorldActionsCommand}" />
                            </StackPanel.InputBindings>
                            <TextBlock Text="FACILITY OVERSEER"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="{StaticResource TextBrush}" />
                            <TextBlock Text="v1.1.0"
                                       VerticalAlignment="Bottom" Margin="6,0,0,4"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock VerticalAlignment="Center" Margin="7,3,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource MutedTextBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="&#x25B8;" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding AreWorldActionsExpanded}" Value="True">
                                                <Setter Property="Text" Value="&#x25BE;" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <TextBlock Text="{Binding HeaderInfoText}"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource MutedTextBrush}" />
                    </StackPanel>
                </StackPanel>
                <Button DockPanel.Dock="Left" Content="Prepare / Update Server"
                        Style="{StaticResource AccentButton}"
                        ToolTip="Download, install, or update the Abiotic Factor dedicated server with SteamCMD."
                        Command="{Binding InstallOrUpdateServerCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />

                <!-- UI Tweaks A2: Create / Clone / Delete / Save grouped into one
                     collapsible cluster that slides away once a world exists. -->
                <StackPanel DockPanel.Dock="Left"
                            Style="{StaticResource WorldActionsClusterStyle}">
                    <Button Content="Create World"
                            ToolTip="Create a new managed world."
                            Command="{Binding CreateWorldCommand}" />
                    <Button Content="Clone"
                            ToolTip="Duplicate the selected world's settings into a new world."
                            Command="{Binding CloneWorldCommand}" />
                    <Button Content="Delete"
                            ToolTip="Delete the selected world's profile (the save files are kept)."
                            Command="{Binding DeleteWorldCommand}" />
                    <Button Content="Save"
                            ToolTip="Save changes to the world profiles."
                            Command="{Binding SaveCommand}" />
                </StackPanel>

                <!-- Compact label-only pill chips. Click = copy. Right-click =
                     secondary actions (lock guidance, show/hide, refresh).
                     The LOBBY chip pins to the header on every tab as soon as
                     the selected world publishes its EOS code. -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,12,0">

                    <!-- LOBBY (only visible when a lobby code is published).
                         Placed FIRST in the StackPanel so it appears on the
                         LEFT of the strip when it spawns in - the LAN and
                         PUB chips stay anchored at the right edge and do
                         not shift sideways the moment the EOS lobby code
                         arrives. -->
                    <Button Style="{StaticResource HeaderChipPill}" Margin="0,0,6,0"
                            Command="{Binding CopyLobbyCodeCommand}"
                            Visibility="{Binding SelectedWorld.LobbyCode, Converter={StaticResource StringToVisibility}, FallbackValue=Collapsed}"
                            ToolTip="{Binding SelectedWorld.LobbyCode, StringFormat='Lobby code: {0}   (click to copy)'}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="LOBBY" VerticalAlignment="Center" />
                            <TextBlock Text="&#x29C9;" Margin="6,0,0,0"
                                       Foreground="{StaticResource ChipGlyphBrush}"
                                       VerticalAlignment="Center" FontSize="13" />
                        </StackPanel>
                    </Button>

                    <!-- Transient "Copied X" / "Copy failed" toast next to the
                         chips. Hidden via Collapsed visibility when empty so
                         the chips do not shift around when it appears.
                         Accent-coloured on success, warn-coloured on failure
                         (driven by IsCopyToastError). Auto-clears after ~1.5s
                         via the DispatcherTimer in MainViewModel. -->
                    <TextBlock Text="{Binding LastCopyToast}"
                               Visibility="{Binding LastCopyToast, Converter={StaticResource StringToVisibility}}"
                               FontSize="11" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,0,10,0">
                        <TextBlock.Style>
                            <Style TargetType="{x:Type TextBlock}">
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCopyToastError}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource WarnBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- LAN -->
                    <Button Style="{StaticResource HeaderChipPill}" Margin="0,0,6,0"
                            Command="{Binding CopyLanIpCommand}"
                            ToolTip="{Binding LanIpv4, StringFormat='LAN IP: {0}   (click to copy, right-click for lock guidance)'}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="LAN" VerticalAlignment="Center" />
                            <TextBlock Text="&#x29C9;" Margin="6,0,0,0"
                                       Foreground="{StaticResource ChipGlyphBrush}"
                                       VerticalAlignment="Center" FontSize="13" />
                        </StackPanel>
                        <Button.ContextMenu>
                            <ContextMenu Background="{StaticResource SurfaceRaisedBrush}">
                                <MenuItem Command="{Binding CopyLanIpCommand}">
                                    <MenuItem.Header>
                                        <TextBlock Text="Copy LAN IP"
                                                   Foreground="{StaticResource TextBrush}" />
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem Command="{Binding ShowLanIpLockGuidanceCommand}">
                                    <MenuItem.Header>
                                        <TextBlock Text="Lock LAN IP (DHCP guidance)"
                                                   Foreground="{StaticResource TextBrush}" />
                                    </MenuItem.Header>
                                </MenuItem>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>

                    <!-- PUB -->
                    <Button Style="{StaticResource HeaderChipPill}" Margin="0,0,6,0"
                            Command="{Binding CopyPublicIpCommand}"
                            ToolTip="{Binding PublicIpv4Display, StringFormat='Public IP: {0}   (right-click to show/hide or refresh)'}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="PUB" VerticalAlignment="Center" />
                            <TextBlock Text="&#x29C9;" Margin="6,0,0,0"
                                       Foreground="{StaticResource ChipGlyphBrush}"
                                       VerticalAlignment="Center" FontSize="13" />
                        </StackPanel>
                        <Button.ContextMenu>
                            <ContextMenu Background="{StaticResource SurfaceRaisedBrush}">
                                <MenuItem Command="{Binding CopyPublicIpCommand}">
                                    <MenuItem.Header>
                                        <TextBlock Text="Copy public IP"
                                                   Foreground="{StaticResource TextBrush}" />
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem Command="{Binding TogglePublicIpVisibilityCommand}">
                                    <MenuItem.Header>
                                        <TextBlock Text="{Binding PublicIpToggleLabel}"
                                                   Foreground="{StaticResource TextBrush}" />
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem Command="{Binding RefreshPublicIpCommand}">
                                    <MenuItem.Header>
                                        <TextBlock Text="Refresh public IP"
                                                   Foreground="{StaticResource TextBrush}" />
                                    </MenuItem.Header>
                                </MenuItem>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>

                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Busy / progress strip -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}"
                CornerRadius="6" Padding="14,12" Margin="0,0,0,12"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <StackPanel>
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Right"
                               Text="{Binding BusyPercentText}"
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"
                               MinWidth="44" TextAlignment="Right" />
                    <TextBlock Text="{Binding BusyTitle}" FontWeight="SemiBold" />
                </DockPanel>

                <ProgressBar Height="10" Margin="0,8,0,0"
                             Minimum="0" Maximum="100"
                             Value="{Binding BusyProgress, FallbackValue=0}"
                             IsIndeterminate="{Binding BusyIsIndeterminate}" />

                <TextBlock Text="{Binding BusyStatus}"
                           Style="{StaticResource MutedText}"
                           Margin="0,6,0,0"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Text="{Binding BusyDetail}"
                           Style="{StaticResource MutedText}"
                           FontFamily="Consolas" FontSize="11"
                           Margin="0,2,0,0"
                           TextTrimming="CharacterEllipsis"
                           Visibility="{Binding BusyDetail, Converter={StaticResource StringToVisibility}}" />
            </StackPanel>
        </Border>

        <!-- LAN IP change banner: visible only when this PC's LAN IPv4 differs from
             the last persisted snapshot. Port forwarding may need attention. -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceAltBrush}"
                BorderBrush="{StaticResource WarnBrush}" BorderThickness="1"
                CornerRadius="4" Padding="12,8" Margin="0,0,0,12"
                VerticalAlignment="Bottom"
                Visibility="{Binding HasInternalIpChangeBanner, Converter={StaticResource BoolToVisibility}}">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right" Content="Dismiss" Margin="12,0,0,0"
                        Command="{Binding DismissInternalIpChangeBannerCommand}" />
                <TextBlock Text="{Binding InternalIpChangeBannerText}"
                           Foreground="{StaticResource WarnBrush}"
                           FontWeight="SemiBold" TextWrapping="Wrap"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <!-- Horizontal world tabs -->
        <TabControl Grid.Row="2"
                    ItemsSource="{Binding Worlds}"
                    SelectedItem="{Binding SelectedWorld, Mode=TwoWay}"
                    Visibility="{Binding HasWorlds, Converter={StaticResource BoolToVisibility}}">
            <TabControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:ServerInstanceViewModel}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="9" Height="9" Margin="0,0,8,0"
                                 ToolTip="{Binding HealthStatusText}"
                                 Fill="{Binding Health, Converter={StaticResource HealthToBrush}}" />
                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                    </StackPanel>
                </DataTemplate>
            </TabControl.ItemTemplate>

            <TabControl.ContentTemplate>
                <DataTemplate DataType="{x:Type vm:ServerInstanceViewModel}">
                    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="6" Padding="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="{StaticResource SurfaceAltBrush}"
                                    BorderBrush="{StaticResource BorderMutedBrush}"
                                    BorderThickness="1" CornerRadius="4" Padding="10,8"
                                    Margin="4,4,4,8">
                                <DockPanel LastChildFill="True">
                                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                        <Button Content="Start" Style="{StaticResource AccentButton}"
                                                Command="{Binding DataContext.StartServerCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                        <Button Content="Stop"
                                                Command="{Binding DataContext.StopServerCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                        <Button Content="Restart"
                                                Command="{Binding DataContext.RestartServerCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                    </StackPanel>
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                                HorizontalAlignment="Right">
                                        <!-- World status dot lives on the tab chip (single source of truth).
                                             Keep only the StatusText label here so health isn't communicated twice. -->
                                        <TextBlock Text="{Binding StatusText}" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </DockPanel>
                            </Border>

                            <TabControl Grid.Row="1" TabStripPlacement="Left"
                                        Style="{StaticResource VerticalRailTabControl}"
                                        PreviewMouseLeftButtonDown="OnVerticalRailMouseDown"
                                        SelectedIndex="{Binding SelectedVerticalTabIndex, Mode=TwoWay}">

                            <!-- ===================== SERVER TAB ===================== -->
                            <!-- Sec 4.8: config-group accent. -->
                            <TabItem Foreground="{StaticResource ConfigTabAccentBrush}">
                                <TabItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#x1F5A5;" FontSize="15" VerticalAlignment="Center" />
                                        <TextBlock Text="Server" Style="{StaticResource MainTabLabel}" />
                                    </StackPanel>
                                </TabItem.Header>
                                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                                    <StackPanel MaxWidth="640" HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                            <TextBlock Text="Server" Style="{StaticResource HeaderText}"
                                                       Margin="0,0,12,0" />
                                            <Button Content="Open World Folder"
                                                    Command="{Binding DataContext.OpenWorldFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                        </StackPanel>

                                        <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="4"
                                                Padding="10,8" Margin="0,0,0,12">
                                            <StackPanel>
                                                <DockPanel LastChildFill="False">
                                                    <Ellipse DockPanel.Dock="Left" Width="11" Height="11"
                                                             Margin="0,0,8,0" VerticalAlignment="Center"
                                                             Fill="{Binding ExternalVisibilityStatus, Converter={StaticResource CheckStatusToBrush}}" />
                                                    <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center"
                                                               FontWeight="SemiBold" Text="External Visibility" />
                                                    <Button DockPanel.Dock="Right" Content="Check Visibility"
                                                            Command="{Binding DataContext.CheckExternalVisibilityCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                </DockPanel>
                                                <TextBlock Text="{Binding ExternalVisibilityText}"
                                                           Style="{StaticResource MutedText}" FontSize="11"
                                                           TextWrapping="Wrap" Margin="19,6,0,0" />
                                            </StackPanel>
                                        </Border>

                                        <TextBlock Text="Server Name" Style="{StaticResource MutedText}" />
                                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,2" />
                                        <TextBlock Style="{StaticResource MutedText}" FontSize="11" Margin="0,0,0,12"
                                                   Text="Used for the tab, the in-game server browser, and the save folder." />

                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="16" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Server Password" Style="{StaticResource MutedText}" />
                                                <Grid Margin="0,2,0,0">
                                                    <PasswordBox x:Name="ServerPwBox"
                                                                 behaviors:PasswordBoxBehavior.IsAttached="True"
                                                                 behaviors:PasswordBoxBehavior.BoundPassword="{Binding ServerPassword, Mode=TwoWay}"
                                                                 Visibility="{Binding IsChecked, ElementName=RevealServerPw, Converter={StaticResource InverseBool}}" />
                                                    <TextBox Text="{Binding ServerPassword, UpdateSourceTrigger=PropertyChanged}"
                                                             Visibility="{Binding IsChecked, ElementName=RevealServerPw, Converter={StaticResource BoolToVisibility}}" />
                                                </Grid>
                                                <CheckBox x:Name="RevealServerPw" Content="Reveal" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Admin Password" Style="{StaticResource MutedText}" />
                                                <Grid Margin="0,2,0,0">
                                                    <PasswordBox behaviors:PasswordBoxBehavior.IsAttached="True"
                                                                 behaviors:PasswordBoxBehavior.BoundPassword="{Binding AdminPassword, Mode=TwoWay}"
                                                                 Visibility="{Binding IsChecked, ElementName=RevealAdminPw, Converter={StaticResource InverseBool}}" />
                                                    <TextBox Text="{Binding AdminPassword, UpdateSourceTrigger=PropertyChanged}"
                                                             Visibility="{Binding IsChecked, ElementName=RevealAdminPw, Converter={StaticResource BoolToVisibility}}" />
                                                </Grid>
                                                <CheckBox x:Name="RevealAdminPw" Content="Reveal" />
                                            </StackPanel>
                                        </Grid>

                                        <TextBlock Text="{Binding MaxPlayers, StringFormat='Max Players: {0}'}" Style="{StaticResource MutedText}" />
                                        <Slider Minimum="1" Maximum="24" TickFrequency="1" IsSnapToTickEnabled="True"
                                                Value="{Binding MaxPlayers}" Margin="0,2,0,12" />

                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="16" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Game Port" Style="{StaticResource MutedText}" />
                                                <TextBox Text="{Binding GamePort, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,0" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Query Port" Style="{StaticResource MutedText}" />
                                                <TextBox Text="{Binding QueryPort, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,0" />
                                            </StackPanel>
                                        </Grid>

                                        <CheckBox Content="LAN Only (server is not expected to appear publicly)"
                                                  IsChecked="{Binding LanOnly}" />
                                        <CheckBox Content="Use Local IPs (can help LAN clients, may break internet joining)"
                                                  IsChecked="{Binding UseLocalIps}" />

                                        <TextBlock Text="Platform Access" Style="{StaticResource MutedText}" Margin="0,12,0,0" />
                                        <ComboBox ItemsSource="{Binding PlatformAccessOptions}"
                                                  DisplayMemberPath="Label"
                                                  SelectedValuePath="Mode"
                                                  SelectedValue="{Binding PlatformAccessMode, Mode=TwoWay}"
                                                  Margin="0,2,0,0" />

                                        <TextBlock Text="Server Folder" Style="{StaticResource MutedText}" Margin="0,12,0,0" />
                                        <TextBox Text="{Binding InstallPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,2" />
                                        <TextBlock Style="{StaticResource MutedText}" FontSize="11" Margin="0,0,0,12"
                                                   Text="Advanced: Facility Overseer prepares the managed server folder automatically. Point this at an existing server only when adopting an external install." />

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                            <Button Content="Validate Config"
                                                    Command="{Binding DataContext.ValidateConfigCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                            <Button Content="Reset Tab to Defaults"
                                                    Command="{Binding DataContext.ResetServerTabCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>

                            <!-- ===================== NETWORK TAB ===================== -->
                            <!-- Sec 4.8: ops-group accent. -->
                            <TabItem Foreground="{StaticResource OpsTabAccentBrush}">
                                <TabItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#x1F310;" FontSize="15" VerticalAlignment="Center" />
                                        <TextBlock Text="Network" Style="{StaticResource MainTabLabel}" />
                                    </StackPanel>
                                </TabItem.Header>
                                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                                    <StackPanel MaxWidth="780" HorizontalAlignment="Left">
                                        <TextBlock Text="Network" Style="{StaticResource HeaderText}" />

                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                            <Button Content="Check Setup"
                                                    Style="{StaticResource AccentButton}"
                                                    Command="{Binding DataContext.CheckNetworkSetupCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                            <Button Content="Create / Repair Windows Firewall Rules"
                                                    Command="{Binding DataContext.CreateFirewallRulesCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                            <Button Content="Copy Router Checklist"
                                                    Command="{Binding DataContext.CopyRouterChecklistCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                            <Button Content="Copy Diagnostics"
                                                    Command="{Binding DataContext.CopyNetworkDiagnosticsCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                        </StackPanel>

                                        <TextBlock Text="{Binding NetworkStatusText}"
                                                   Style="{StaticResource MutedText}"
                                                   Margin="0,0,0,12" />

                                        <!-- Phase B2: pinned Reachability verdict. Single
                                             top-of-panel rollup so the user doesn't have
                                             to parse the granular check list to decide
                                             whether players can actually join. -->
                                        <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="4"
                                                Padding="12" Margin="0,0,0,12">
                                            <DockPanel LastChildFill="True">
                                                <Ellipse DockPanel.Dock="Left" Width="14" Height="14"
                                                         Margin="0,0,10,0" VerticalAlignment="Center"
                                                         Fill="{Binding ReachabilityStatus, Converter={StaticResource NetworkVerdictStatusToBrush}}" />
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="REACHABILITY"
                                                                   Foreground="{StaticResource AccentBrush}"
                                                                   FontWeight="Bold" VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding ReachabilityHeadline}"
                                                                   FontWeight="SemiBold" VerticalAlignment="Center"
                                                                   Margin="10,0,0,0" />
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding ReachabilityDetail}"
                                                               Style="{StaticResource MutedText}"
                                                               TextWrapping="Wrap" Margin="0,4,0,0" />
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>

                                        <!-- Sec 4.9 lobby code: the in-game "LOBBY CODE" players can type to
                                             join directly. Captured from the running server's EOS session log. -->
                                        <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="4"
                                                Padding="12" Margin="0,0,0,12"
                                                Visibility="{Binding LobbyCode, Converter={StaticResource StringToVisibility}}">
                                            <StackPanel>
                                                <TextBlock Text="LOBBY CODE" Foreground="{StaticResource AccentBrush}"
                                                           FontWeight="Bold" Margin="0,0,0,6" />
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="3"
                                                            Padding="14,4" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding LobbyCode}" FontFamily="Consolas"
                                                                   FontSize="18" FontWeight="Bold" />
                                                    </Border>
                                                    <Button Content="Copy" Margin="8,0,0,0" VerticalAlignment="Center"
                                                            Command="{Binding DataContext.CopyLobbyCodeCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                </StackPanel>
                                                <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap"
                                                           Margin="0,6,0,0"
                                                           Text="Friends can enter this code in Abiotic Factor to join directly - no IP address needed. It changes each time the server restarts. If the server has a password, players still need it." />
                                            </StackPanel>
                                        </Border>

                                        <!-- Sec 4.7 network confidence: 0-100 score + band + how to improve. -->
                                        <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="4"
                                                Padding="12" Margin="0,0,0,12"
                                                Visibility="{Binding HasNetworkConfidence, Converter={StaticResource BoolToVisibility}}">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="NETWORK CONFIDENCE"
                                                               Foreground="{StaticResource AccentBrush}"
                                                               FontWeight="Bold" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding NetworkConfidenceSummary}"
                                                               FontWeight="SemiBold" VerticalAlignment="Center"
                                                               Margin="10,0,0,0" />
                                                </StackPanel>
                                                <ItemsControl ItemsSource="{Binding NetworkConfidenceStrengths}"
                                                              Margin="0,8,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding}" Style="{StaticResource MutedText}"
                                                                       TextWrapping="Wrap" Margin="0,1" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <ItemsControl ItemsSource="{Binding NetworkConfidenceLifts}"
                                                              Margin="0,6,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding StringFormat='To improve: {0}'}"
                                                                       TextWrapping="Wrap" Margin="0,1" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>

                                        <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="4"
                                                Padding="12" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="CURRENT WORLD NETWORK SETTINGS"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           FontWeight="Bold" Margin="0,0,0,8" />

                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="160" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                                               Text="World" Style="{StaticResource MutedText}" />
                                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                                               Text="{Binding DisplayName}" />

                                                    <TextBlock Grid.Row="1" Grid.Column="0"
                                                               Text="Game UDP" Style="{StaticResource MutedText}" />
                                                    <TextBlock Grid.Row="1" Grid.Column="1"
                                                               Text="{Binding GamePort}" />

                                                    <TextBlock Grid.Row="2" Grid.Column="0"
                                                               Text="Query UDP" Style="{StaticResource MutedText}" />
                                                    <TextBlock Grid.Row="2" Grid.Column="1"
                                                               Text="{Binding QueryPort}" />

                                                    <TextBlock Grid.Row="3" Grid.Column="0"
                                                               Text="Server executable" Style="{StaticResource MutedText}" />
                                                    <TextBlock Grid.Row="3" Grid.Column="1"
                                                               Text="{Binding ServerExecutableText}" TextWrapping="Wrap" />

                                                    <TextBlock Grid.Row="4" Grid.Column="0"
                                                               Text="Current LAN IPv4" Style="{StaticResource MutedText}" />
                                                    <TextBlock Grid.Row="4" Grid.Column="1"
                                                               Text="{Binding RouterTargetText}" TextWrapping="Wrap" />
                                                </Grid>

                                                <TextBlock Text="{Binding LastFirewallRepairText}"
                                                           Style="{StaticResource MutedText}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>

                                        <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="4"
                                                Padding="12" Margin="0,0,0,12">
                                            <StackPanel>
                                                <StackPanel.Resources>
                                                    <!-- Group the checks by Category so the Check Setup
                                                         results read as a few collapsible troubleshooting
                                                         sections instead of one long flat list. -->
                                                    <CollectionViewSource x:Key="GroupedChecks"
                                                                          Source="{Binding NetworkChecks}">
                                                        <CollectionViewSource.GroupDescriptions>
                                                            <PropertyGroupDescription PropertyName="Category" />
                                                        </CollectionViewSource.GroupDescriptions>
                                                    </CollectionViewSource>
                                                </StackPanel.Resources>

                                                <TextBlock Text="DIAGNOSTIC CHECKS"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           FontWeight="Bold" Margin="0,0,0,8" />
                                                <TextBlock Text="{Binding FirewallSummaryText}"
                                                           TextWrapping="Wrap" Margin="0,0,0,10" />

                                                <ItemsControl ItemsSource="{Binding Source={StaticResource GroupedChecks}}">
                                                    <!-- One collapsible section per check category. -->
                                                    <ItemsControl.GroupStyle>
                                                        <GroupStyle>
                                                            <GroupStyle.ContainerStyle>
                                                                <Style TargetType="GroupItem">
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="GroupItem">
                                                                                <Expander IsExpanded="True" Margin="0,0,0,8"
                                                                                          Background="{StaticResource SurfaceBrush}"
                                                                                          Padding="8,4">
                                                                                    <Expander.Header>
                                                                                        <TextBlock FontWeight="Bold">
                                                                                            <Run Text="{Binding Name, Mode=OneWay}" />
                                                                                            <Run Text="{Binding ItemCount, Mode=OneWay, StringFormat=' ({0})'}"
                                                                                                 Foreground="{StaticResource MutedTextBrush}" />
                                                                                        </TextBlock>
                                                                                    </Expander.Header>
                                                                                    <ItemsPresenter Margin="0,6,0,0" />
                                                                                </Expander>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Style>
                                                            </GroupStyle.ContainerStyle>
                                                        </GroupStyle>
                                                    </ItemsControl.GroupStyle>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <!-- Compact per-check row: status + label always
                                                                 visible; value / summary / fix on expand. -->
                                                            <Border Background="{StaticResource SurfaceBrush}"
                                                                    CornerRadius="4" Margin="0,0,0,4">
                                                                <Expander Padding="8,2">
                                                                    <Expander.Header>
                                                                        <DockPanel LastChildFill="True" MinWidth="420">
                                                                            <TextBlock DockPanel.Dock="Right"
                                                                                       Text="{Binding StatusLabel}"
                                                                                       Foreground="{Binding Status, Converter={StaticResource NetworkCheckStatusToBrush}}"
                                                                                       FontWeight="SemiBold"
                                                                                       Margin="12,0,0,0" />
                                                                            <TextBlock Text="{Binding Label}"
                                                                                       FontWeight="SemiBold"
                                                                                       VerticalAlignment="Center" />
                                                                        </DockPanel>
                                                                    </Expander.Header>
                                                                    <StackPanel Margin="0,4,0,6">
                                                                        <TextBlock Text="{Binding Value}"
                                                                                   FontFamily="Consolas"
                                                                                   Style="{StaticResource MutedText}"
                                                                                   TextWrapping="WrapWithOverflow"
                                                                                   Visibility="{Binding Value, Converter={StaticResource StringToVisibility}}" />
                                                                        <TextBlock Text="{Binding Summary}"
                                                                                   TextWrapping="Wrap"
                                                                                   Margin="0,4,0,0" />
                                                                        <TextBlock Text="{Binding Details}"
                                                                                   Style="{StaticResource MutedText}"
                                                                                   TextWrapping="Wrap"
                                                                                   Margin="0,3,0,0"
                                                                                   Visibility="{Binding Details, Converter={StaticResource StringToVisibility}}" />
                                                                        <TextBlock Text="{Binding Remediation}"
                                                                                   Foreground="{StaticResource WarnBrush}"
                                                                                   TextWrapping="Wrap"
                                                                                   Margin="0,3,0,0"
                                                                                   Visibility="{Binding Remediation, Converter={StaticResource StringToVisibility}}" />
                                                                    </StackPanel>
                                                                </Expander>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>

                                        <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="4"
                                                Padding="12" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="ROUTER PORT FORWARDING"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           FontWeight="Bold" Margin="0,0,0,8" />

                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="150" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                                               Text="Router target" Style="{StaticResource MutedText}" />
                                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                                               Text="{Binding RouterTargetText}" TextWrapping="Wrap" />

                                                    <TextBlock Grid.Row="1" Grid.Column="0"
                                                               Text="Game UDP port" Style="{StaticResource MutedText}" />
                                                    <TextBlock Grid.Row="1" Grid.Column="1"
                                                               Text="{Binding GamePort}" />

                                                    <TextBlock Grid.Row="2" Grid.Column="0"
                                                               Text="Query UDP port" Style="{StaticResource MutedText}" />
                                                    <TextBlock Grid.Row="2" Grid.Column="1"
                                                               Text="{Binding QueryPort}" />
                                                </Grid>

                                                <ItemsControl ItemsSource="{Binding RouterChecklist}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <DockPanel Margin="0,0,0,5">
                                                                <TextBlock DockPanel.Dock="Left" Text="- " Style="{StaticResource MutedText}" />
                                                                <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                                            </DockPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>

                                        <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="4"
                                                Padding="12">
                                            <StackPanel>
                                                <TextBlock Text="LOCAL IPv4 ADDRESSES"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           FontWeight="Bold" Margin="0,0,0,8" />
                                                <ItemsControl ItemsSource="{Binding LocalIpv4Addresses}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding}" FontFamily="Consolas" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>

                            <!-- Sec 4.x dynamic sandbox tabs: one sub-tab per category discovered
                                 in SandboxSettings.ini. A new category in a future game update
                                 appears here automatically - nothing is hardcoded. The Save
                                 Sandbox bar is world-level so it sits once above the sub-tabs. -->
                            <TabItem Foreground="{StaticResource ConfigTabAccentBrush}">
                                <TabItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#x1F3AE;" FontSize="15" VerticalAlignment="Center" />
                                        <TextBlock Text="Game Settings" Style="{StaticResource MainTabLabel}" />
                                    </StackPanel>
                                </TabItem.Header>
                                <DockPanel>
                                    <ContentControl DockPanel.Dock="Top"
                                                    ContentTemplate="{StaticResource SandboxToolbar}"
                                                    Content="{Binding}" />
                                    <TextBlock DockPanel.Dock="Top" Margin="16,12,16,0"
                                               Style="{StaticResource MutedText}" TextWrapping="Wrap"
                                               Text="Create a world and install the server to populate these settings. Tabs are generated from the categories Abiotic Factor reports."
                                               Visibility="{Binding Sandbox.HasCategories, Converter={StaticResource InvBoolToVisibility}}" />
                                    <TabControl ItemsSource="{Binding Sandbox.Categories}"
                                                TabStripPlacement="Left"
                                                ItemContainerStyle="{StaticResource InteriorTabItem}"
                                                Background="Transparent" Margin="0,6,0,0"
                                                Visibility="{Binding Sandbox.HasCategories, Converter={StaticResource BoolToVisibility}}">
                                        <TabControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name, Converter={StaticResource CategoryIcon}}"
                                                               FontSize="14" VerticalAlignment="Center" Margin="0,0,7,0" />
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </TabControl.ItemTemplate>
                                        <TabControl.ContentTemplate>
                                            <DataTemplate>
                                                <local:SandboxCategoryPanel
                                                    ItemsSource="{Binding Settings}"
                                                    EmptyHint="{Binding EmptyHint}" />
                                            </DataTemplate>
                                        </TabControl.ContentTemplate>
                                    </TabControl>
                                </DockPanel>
                            </TabItem>
                            <TabItem Foreground="{StaticResource OpsTabAccentBrush}">
                                <TabItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#x1F4BE;" FontSize="15" VerticalAlignment="Center" />
                                        <TextBlock Text="Backups" Style="{StaticResource MainTabLabel}" />
                                    </StackPanel>
                                </TabItem.Header>
                                <Grid Margin="20">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Text="Backups"
                                               Style="{StaticResource HeaderText}" />

                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,8">
                                        <Button Content="Backup Now" Style="{StaticResource AccentButton}"
                                                Command="{Binding DataContext.BackupNowCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                        <Button Content="Restore Selected"
                                                Command="{Binding DataContext.RestoreBackupCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                        <Button Content="Open Backup Folder"
                                                Command="{Binding DataContext.OpenBackupsFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                    </StackPanel>

                                    <TextBlock Grid.Row="2" Text="{Binding BackupStatusText}"
                                               Style="{StaticResource MutedText}" Margin="0,0,0,12"
                                               TextWrapping="Wrap" />

                                    <Border Grid.Row="3" Background="{StaticResource SurfaceAltBrush}"
                                            CornerRadius="4" Padding="6">
                                        <Grid>
                                        <TextBlock TextWrapping="Wrap" Margin="10,8"
                                                   VerticalAlignment="Top"
                                                   Style="{StaticResource MutedText}"
                                                   Visibility="{Binding HasItems, ElementName=BackupsList, Converter={StaticResource InvBoolToVisibility}}"
                                                   Text="No backups yet. Use 'Backup Now' to create one. Facility Overseer also backs up automatically before risky actions (deleting a world, saving sandbox settings, updating the server). Each backup includes the world save, SandboxSettings.ini, Admins.ini and the world profile." />
                                        <ListBox x:Name="BackupsList"
                                                 ItemsSource="{Binding Backups}"
                                                 SelectedItem="{Binding SelectedBackup, Mode=TwoWay}"
                                                 Background="Transparent" BorderThickness="0"
                                                 HorizontalContentAlignment="Stretch">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="10,6" Margin="0,0,0,3"
                                                            Background="{StaticResource SurfaceBrush}"
                                                            CornerRadius="4">
                                                        <StackPanel>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"
                                                                           FontWeight="SemiBold" />
                                                                <TextBlock Text="{Binding Reason, StringFormat='  -  {0}'}"
                                                                           Style="{StaticResource MutedText}" />
                                                                <TextBlock Text="{Binding SizeText, StringFormat='  -  {0}'}"
                                                                           Style="{StaticResource MutedText}" />
                                                            </StackPanel>
                                                            <!-- Sec 4.4 backup confidence badge: Full / Partial / Limited
                                                                 + age, evaluated at bind time. Tooltip explains gaps. -->
                                                            <ContentControl Content="{Binding Converter={StaticResource BackupConfidence}}"
                                                                            HorizontalAlignment="Left" Margin="0,4,0,0">
                                                                <ContentControl.ContentTemplate>
                                                                    <DataTemplate>
                                                                        <StackPanel Orientation="Horizontal" ToolTip="{Binding Detail}">
                                                                            <Border CornerRadius="3" Padding="7,1" VerticalAlignment="Center">
                                                                                <Border.Style>
                                                                                    <Style TargetType="Border">
                                                                                        <Setter Property="Background" Value="#A8B5C1" />
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding Level}" Value="Full">
                                                                                                <Setter Property="Background" Value="#79D66B" />
                                                                                            </DataTrigger>
                                                                                            <DataTrigger Binding="{Binding Level}" Value="Partial">
                                                                                                <Setter Property="Background" Value="#E6B84B" />
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </Border.Style>
                                                                                <TextBlock Text="{Binding Label}" FontWeight="SemiBold"
                                                                                           FontSize="11" Foreground="#0B0F14" />
                                                                            </Border>
                                                                            <TextBlock Text="{Binding AgeLabel}" Style="{StaticResource MutedText}"
                                                                                       VerticalAlignment="Center" Margin="8,0,0,0" />
                                                                            <TextBlock Text="- stale" FontSize="11" FontWeight="SemiBold"
                                                                                       Foreground="#E6B84B" VerticalAlignment="Center"
                                                                                       Margin="6,0,0,0"
                                                                                       Visibility="{Binding IsStale, Converter={StaticResource BoolToVisibility}}" />
                                                                        </StackPanel>
                                                                    </DataTemplate>
                                                                </ContentControl.ContentTemplate>
                                                            </ContentControl>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </TabItem>

                            <!-- ===================== LOGS &amp; STATUS ===================== -->
                            <TabItem Foreground="{StaticResource OpsTabAccentBrush}">
                                <TabItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#x1F4CB;" FontSize="15" VerticalAlignment="Center" />
                                        <TextBlock Text="Logs &amp; Status" Style="{StaticResource MainTabLabel}" />
                                    </StackPanel>
                                </TabItem.Header>
                                <Grid Margin="20">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <DockPanel Grid.Row="0" Margin="0,0,0,12" LastChildFill="False">
                                        <StackPanel DockPanel.Dock="Left">
                                            <StackPanel Orientation="Horizontal">
                                                <!-- World status dot lives on the tab chip (single source of truth).
                                                     Keep only the label and the health detail line here. -->
                                                <TextBlock Text="{Binding StatusText}" FontWeight="SemiBold"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding HealthDetail}"
                                                       Style="{StaticResource MutedText}"
                                                       FontSize="11" Margin="19,2,0,0"
                                                       TextWrapping="Wrap" MaxWidth="520"
                                                       HorizontalAlignment="Left" />
                                        </StackPanel>
                                        <Button Content="Validate Config"
                                                DockPanel.Dock="Right"
                                                Command="{Binding DataContext.ValidateConfigCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                        <Button Content="Create Fresh World"
                                                DockPanel.Dock="Right" Margin="0,0,8,0"
                                                Command="{Binding DataContext.CreateFreshWorldCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                        <Button Content="Open World Folder"
                                                DockPanel.Dock="Right" Margin="0,0,8,0"
                                                Command="{Binding DataContext.OpenWorldFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                    </DockPanel>

                                    <!-- Sec 4.6 startup sequence timeline: 7-phase progress, shown while the
                                         server is starting/running or after a failed startup. -->
                                    <Border Grid.Row="1" Background="{StaticResource SurfaceAltBrush}"
                                            CornerRadius="4" Padding="12,8" Margin="0,0,0,10"
                                            Visibility="{Binding HasStartupSequence, Converter={StaticResource BoolToVisibility}}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding StartupSummary}" FontWeight="SemiBold"
                                                       Margin="0,0,0,6" TextWrapping="Wrap" />
                                            <ItemsControl ItemsSource="{Binding StartupPhases}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                                                    Margin="0,2,12,2">
                                                            <Ellipse Width="10" Height="10" VerticalAlignment="Center"
                                                                     Fill="{Binding Status, Converter={StaticResource StartupPhaseStatusToBrush}}" />
                                                            <TextBlock Text="{Binding Label}" FontSize="11"
                                                                       VerticalAlignment="Center" Margin="5,0,0,0" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                    <TabControl Grid.Row="2" Background="Transparent"
                                                ItemContainerStyle="{StaticResource InteriorTabItem}"
                                                SelectedIndex="{Binding LogsSubTabIndex, Mode=TwoWay}">
                                        <TabItem Header="Log">
                                            <Grid Margin="0,10,0,0">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>

                                                <!-- Phase 2 guidance stack: Sec 4.3 recommended actions, Sec 4.5 world
                                                     integrity, and the Sec 4.1 diagnostic cards. Centered, width-capped,
                                                     height-capped with a scroll so a long stack never pushes the
                                                     log offscreen. -->
                                                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto"
                                                              HorizontalScrollBarVisibility="Disabled"
                                                              MaxHeight="300" Margin="0,0,0,12">
                                                    <!-- Width (not MaxWidth) so the inner WrapPanel always has the
                                                         full 720px to lay out diagnostic cards side by side.
                                                         MaxWidth let the StackPanel shrink to its widest child,
                                                         leaving the WrapPanel with the card's own width and
                                                         forcing every card onto its own row. -->
                                                    <StackPanel HorizontalAlignment="Center" Width="720">

                                                        <!-- Sec 4.2 guided recovery flow: shown when the world is
                                                             Blocked; ordered steps with one-click action buttons. -->
                                                        <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="4"
                                                                BorderBrush="#FF5F57" BorderThickness="1"
                                                                Padding="12,10" Margin="0,0,0,6"
                                                                Visibility="{Binding HasRecoveryFlow, Converter={StaticResource BoolToVisibility}}">
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding RecoveryFlowTitle}" FontWeight="Bold"
                                                                           FontSize="13" Foreground="#FF8A84"
                                                                           TextWrapping="Wrap" />
                                                                <TextBlock Text="{Binding RecoveryFlowSummary}"
                                                                           Style="{StaticResource MutedText}"
                                                                           TextWrapping="Wrap" Margin="0,4,0,8" />
                                                                <ItemsControl ItemsSource="{Binding RecoverySteps}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Grid Margin="0,3">
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="Auto" />
                                                                                    <ColumnDefinition Width="*" />
                                                                                    <ColumnDefinition Width="Auto" />
                                                                                </Grid.ColumnDefinitions>
                                                                                <TextBlock Grid.Column="0" FontWeight="SemiBold"
                                                                                           Margin="0,0,8,0" VerticalAlignment="Top"
                                                                                           Text="{Binding Order, StringFormat='{}{0}.'}" />
                                                                                <StackPanel Grid.Column="1">
                                                                                    <TextBlock Text="{Binding Title}"
                                                                                               FontWeight="SemiBold" TextWrapping="Wrap" />
                                                                                    <TextBlock Text="{Binding Detail}"
                                                                                               Style="{StaticResource MutedText}"
                                                                                               TextWrapping="Wrap" />
                                                                                </StackPanel>
                                                                                <Button Grid.Column="2" Content="{Binding ActionLabel}"
                                                                                        Margin="8,0,0,0" VerticalAlignment="Top"
                                                                                        Visibility="{Binding ActionHint, Converter={StaticResource StringToVisibility}}"
                                                                                        Command="{Binding DataContext.RunRecoveryStepCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                        CommandParameter="{Binding}" />
                                                                            </Grid>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                        </Border>

                                                        <!-- Unified notification strip: Sec 4.3 recommended actions,
                                                             Sec 4.5 integrity findings, and Sec 4.1 individual
                                                             diagnostics share one WrapPanel. Every chip is a
                                                             ToggleButton + Popup so clicks open a dropdown that
                                                             overlays the log view instead of pushing the UI. -->
                                                        <ItemsControl ItemsSource="{Binding NotificationChips}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel Orientation="Horizontal" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.Resources>

                                                                <!-- Recommended next steps summary chip. Popup hosts
                                                                     the full ranked action list with Do-this buttons. -->
                                                                <DataTemplate DataType="{x:Type vm:RecommendedActionsChip}">
                                                                    <Grid>
                                                                        <ToggleButton x:Name="ChipReco"
                                                                                      Style="{StaticResource NotificationChipToggle}"
                                                                                      Width="234"
                                                                                      ToolTip="Recommended next steps for this world.">
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <Ellipse Width="9" Height="9" Margin="0,0,8,0"
                                                                                         VerticalAlignment="Center" Fill="#3DA9F5" />
                                                                                <TextBlock Text="Recommended next steps"
                                                                                           FontWeight="SemiBold"
                                                                                           VerticalAlignment="Center"
                                                                                           TextTrimming="CharacterEllipsis" />
                                                                            </StackPanel>
                                                                        </ToggleButton>
                                                                        <Popup PlacementTarget="{Binding ElementName=ChipReco}"
                                                                               Placement="Bottom"
                                                                               IsOpen="{Binding IsChecked, ElementName=ChipReco, Mode=TwoWay}"
                                                                               AllowsTransparency="True" StaysOpen="False"
                                                                               PopupAnimation="Fade">
                                                                            <Border Background="{StaticResource SurfaceRaisedBrush}"
                                                                                    BorderBrush="{StaticResource BorderBrush}"
                                                                                    BorderThickness="1" CornerRadius="4"
                                                                                    Padding="12" Width="460" MaxHeight="360"
                                                                                    Margin="0,4,0,0">
                                                                                <DockPanel>
                                                                                    <TextBlock DockPanel.Dock="Top" Text="Recommended next steps"
                                                                                               FontWeight="Bold" FontSize="14"
                                                                                               Margin="0,0,0,8" />
                                                                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                                                        <ItemsControl ItemsSource="{Binding World.RecommendedActions}">
                                                                                            <ItemsControl.ItemTemplate>
                                                                                                <DataTemplate>
                                                                                                    <Border Background="{StaticResource SurfaceAltBrush}"
                                                                                                            CornerRadius="4" Padding="10,8" Margin="0,0,0,6">
                                                                                                        <Grid>
                                                                                                            <Grid.ColumnDefinitions>
                                                                                                                <ColumnDefinition Width="Auto" />
                                                                                                                <ColumnDefinition Width="*" />
                                                                                                                <ColumnDefinition Width="Auto" />
                                                                                                            </Grid.ColumnDefinitions>
                                                                                                            <Ellipse Grid.Column="0" Width="9" Height="9"
                                                                                                                     Margin="0,4,8,0" VerticalAlignment="Top"
                                                                                                                     Fill="{Binding Priority, Converter={StaticResource RecommendedPriorityToBrush}}" />
                                                                                                            <StackPanel Grid.Column="1">
                                                                                                                <TextBlock Text="{Binding Title}"
                                                                                                                           FontWeight="SemiBold" TextWrapping="Wrap" />
                                                                                                                <TextBlock Text="{Binding Detail}"
                                                                                                                           Style="{StaticResource MutedText}"
                                                                                                                           TextWrapping="Wrap" />
                                                                                                            </StackPanel>
                                                                                                            <Button Grid.Column="2" Content="Do this"
                                                                                                                    Margin="8,0,0,0" VerticalAlignment="Top"
                                                                                                                    Visibility="{Binding CommandHint, Converter={StaticResource StringToVisibility}}"
                                                                                                                    Command="{Binding DataContext.RunRecommendedActionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                                                    CommandParameter="{Binding}" />
                                                                                                        </Grid>
                                                                                                    </Border>
                                                                                                </DataTemplate>
                                                                                            </ItemsControl.ItemTemplate>
                                                                                        </ItemsControl>
                                                                                    </ScrollViewer>
                                                                                </DockPanel>
                                                                            </Border>
                                                                        </Popup>
                                                                    </Grid>
                                                                </DataTemplate>

                                                                <!-- Integrity findings summary chip. Popup hosts the full
                                                                     finding list with severity dots and fix buttons. -->
                                                                <DataTemplate DataType="{x:Type vm:IntegrityFindingsChip}">
                                                                    <Grid>
                                                                        <ToggleButton x:Name="ChipInt"
                                                                                      Style="{StaticResource NotificationChipToggle}"
                                                                                      Width="234"
                                                                                      ToolTip="{Binding World.IntegritySummary}">
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <Ellipse Width="9" Height="9" Margin="0,0,8,0"
                                                                                         VerticalAlignment="Center" Fill="#E6B84B" />
                                                                                <TextBlock Text="{Binding World.IntegritySummary}"
                                                                                           FontWeight="SemiBold"
                                                                                           VerticalAlignment="Center"
                                                                                           TextTrimming="CharacterEllipsis" />
                                                                            </StackPanel>
                                                                        </ToggleButton>
                                                                        <Popup PlacementTarget="{Binding ElementName=ChipInt}"
                                                                               Placement="Bottom"
                                                                               IsOpen="{Binding IsChecked, ElementName=ChipInt, Mode=TwoWay}"
                                                                               AllowsTransparency="True" StaysOpen="False"
                                                                               PopupAnimation="Fade">
                                                                            <Border Background="{StaticResource SurfaceRaisedBrush}"
                                                                                    BorderBrush="{StaticResource BorderBrush}"
                                                                                    BorderThickness="1" CornerRadius="4"
                                                                                    Padding="12" Width="460" MaxHeight="360"
                                                                                    Margin="0,4,0,0">
                                                                                <DockPanel>
                                                                                    <TextBlock DockPanel.Dock="Top" Text="{Binding World.IntegritySummary}"
                                                                                               FontWeight="Bold" FontSize="14"
                                                                                               TextWrapping="Wrap" Margin="0,0,0,8" />
                                                                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                                                        <ItemsControl ItemsSource="{Binding World.IntegrityFindings}">
                                                                                            <ItemsControl.ItemTemplate>
                                                                                                <DataTemplate>
                                                                                                    <Border Background="{StaticResource SurfaceAltBrush}"
                                                                                                            CornerRadius="4" Margin="0,0,0,6">
                                                                                                        <Expander Padding="10,4">
                                                                                                            <Expander.Header>
                                                                                                                <StackPanel Orientation="Horizontal">
                                                                                                                    <Ellipse Width="9" Height="9" Margin="0,0,8,0"
                                                                                                                             VerticalAlignment="Center"
                                                                                                                             Fill="{Binding Severity, Converter={StaticResource IntegritySeverityToBrush}}" />
                                                                                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                                                                                                               VerticalAlignment="Center" TextWrapping="Wrap" />
                                                                                                                </StackPanel>
                                                                                                            </Expander.Header>
                                                                                                            <StackPanel Margin="17,4,0,6">
                                                                                                                <TextBlock Text="{Binding Detail}"
                                                                                                                           Style="{StaticResource MutedText}"
                                                                                                                           TextWrapping="Wrap" />
                                                                                                                <TextBlock Text="{Binding SuggestedFix}"
                                                                                                                           Style="{StaticResource MutedText}"
                                                                                                                           TextWrapping="Wrap" FontStyle="Italic"
                                                                                                                           Margin="0,4,0,0"
                                                                                                                           Visibility="{Binding SuggestedFix, Converter={StaticResource StringToVisibility}}" />
                                                                                                                <Button Content="{Binding ActionLabel}"
                                                                                                                        Margin="0,8,0,0" HorizontalAlignment="Left"
                                                                                                                        Padding="12,5"
                                                                                                                        Visibility="{Binding CommandHint, Converter={StaticResource StringToVisibility}}"
                                                                                                                        Command="{Binding DataContext.RunIntegrityActionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                                                        CommandParameter="{Binding}" />
                                                                                                            </StackPanel>
                                                                                                        </Expander>
                                                                                                    </Border>
                                                                                                </DataTemplate>
                                                                                            </ItemsControl.ItemTemplate>
                                                                                        </ItemsControl>
                                                                                    </ScrollViewer>
                                                                                </DockPanel>
                                                                            </Border>
                                                                        </Popup>
                                                                    </Grid>
                                                                </DataTemplate>

                                                                <!-- Individual diagnostic chip: one per DiagnosticMessage.
                                                                     Popup shows that diagnostic's message and suggested fix. -->
                                                                <DataTemplate DataType="{x:Type diag:DiagnosticMessage}">
                                                                    <Grid>
                                                                        <ToggleButton x:Name="ChipDiag"
                                                                                      Style="{StaticResource NotificationChipToggle}"
                                                                                      Width="234"
                                                                                      ToolTip="{Binding Title}">
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <Ellipse Width="9" Height="9" Margin="0,0,8,0"
                                                                                         VerticalAlignment="Center"
                                                                                         Fill="{Binding Severity, Converter={StaticResource SeverityToBrush}}" />
                                                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                                                                           VerticalAlignment="Center"
                                                                                           TextTrimming="CharacterEllipsis" />
                                                                                <TextBlock Text="{Binding Code, StringFormat=' [{0}]'}"
                                                                                           Style="{StaticResource MutedText}"
                                                                                           VerticalAlignment="Center"
                                                                                           TextTrimming="CharacterEllipsis" />
                                                                            </StackPanel>
                                                                        </ToggleButton>
                                                                        <Popup PlacementTarget="{Binding ElementName=ChipDiag}"
                                                                               Placement="Bottom"
                                                                               IsOpen="{Binding IsChecked, ElementName=ChipDiag, Mode=TwoWay}"
                                                                               AllowsTransparency="True" StaysOpen="False"
                                                                               PopupAnimation="Fade">
                                                                            <Border Background="{StaticResource SurfaceRaisedBrush}"
                                                                                    BorderBrush="{StaticResource BorderBrush}"
                                                                                    BorderThickness="1" CornerRadius="4"
                                                                                    Padding="12" Width="360" MaxHeight="280"
                                                                                    Margin="0,4,0,0">
                                                                                <DockPanel>
                                                                                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                                                                                                Margin="0,0,0,8">
                                                                                        <Ellipse Width="10" Height="10" Margin="0,0,8,0"
                                                                                                 VerticalAlignment="Center"
                                                                                                 Fill="{Binding Severity, Converter={StaticResource SeverityToBrush}}" />
                                                                                        <TextBlock Text="{Binding Title}" FontWeight="Bold"
                                                                                                   FontSize="14" TextWrapping="Wrap" />
                                                                                        <TextBlock Text="{Binding Code, StringFormat=' [{0}]'}"
                                                                                                   Style="{StaticResource MutedText}"
                                                                                                   VerticalAlignment="Center" />
                                                                                    </StackPanel>
                                                                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                                                        <StackPanel>
                                                                                            <TextBlock Text="{Binding Message}"
                                                                                                       Style="{StaticResource MutedText}"
                                                                                                       TextWrapping="Wrap" />
                                                                                            <TextBlock Text="{Binding SuggestedFix}"
                                                                                                       Style="{StaticResource MutedText}"
                                                                                                       TextWrapping="Wrap"
                                                                                                       FontStyle="Italic" Margin="0,8,0,0"
                                                                                                       Visibility="{Binding SuggestedFix, Converter={StaticResource StringToVisibility}}" />
                                                                                        </StackPanel>
                                                                                    </ScrollViewer>
                                                                                </DockPanel>
                                                                            </Border>
                                                                        </Popup>
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </ItemsControl.Resources>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </ScrollViewer>

                                                <Border Grid.Row="1" Background="{StaticResource LogBackgroundBrush}" CornerRadius="4" Padding="8">
                                                    <ListBox ItemsSource="{Binding LogLines}"
                                                             Background="Transparent" BorderThickness="0"
                                                             Foreground="{StaticResource LogTextBrush}"
                                                             FontFamily="Consolas" FontSize="12"
                                                             behaviors:AutoScrollBehavior.StickToBottom="True"
                                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                             ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                                        <ListBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding DisplayText}" TextWrapping="Wrap">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="{x:Type TextBlock}">
                                                                            <Setter Property="Foreground" Value="{StaticResource LogTextBrush}" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Severity}" Value="Warning">
                                                                                    <Setter Property="Foreground" Value="{StaticResource WarnBrush}" />
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Severity}" Value="Error">
                                                                                    <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </DataTemplate>
                                                        </ListBox.ItemTemplate>
                                                    </ListBox>
                                                </Border>
                                            </Grid>
                                        </TabItem>

                                        <TabItem Header="Players">
                                            <Grid Margin="0,10,0,0">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>

                                                <Border Grid.Row="0" Background="{StaticResource SurfaceAltBrush}"
                                                        CornerRadius="4" Padding="12,10" Margin="0,0,0,10">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding PlayersOnlineText}"
                                                                   FontWeight="SemiBold" TextWrapping="Wrap" />
                                                        <TextBlock Style="{StaticResource MutedText}" FontSize="11"
                                                                   Margin="0,2,0,0" TextWrapping="Wrap"
                                                                   Text="Roster is built from the live Abiotic Factor server log and remembered per world. Double-click a player to open their detail tab." />
                                                    </StackPanel>
                                                </Border>

                                                <Border Grid.Row="1" Background="{StaticResource SurfaceAltBrush}"
                                                        CornerRadius="4" Padding="8" Margin="0,0,0,10">
                                                    <DockPanel>
                                                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8" LastChildFill="False">
                                                            <Button DockPanel.Dock="Left" Content="Ban Selected"
                                                                    Command="{Binding DataContext.BanSelectedPlayerCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                            <Button DockPanel.Dock="Left" Content="Unban Selected" Margin="8,0,0,0"
                                                                    Command="{Binding DataContext.UnbanSelectedPlayerCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                            <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center"
                                                                       Margin="14,0,0,0" Style="{StaticResource MutedText}"
                                                                       FontSize="11" TextWrapping="Wrap"
                                                                       Text="Select a player, then Ban (writes Admin.ini). A live kick needs Abiotic Factor's remote console, which is disabled by default." />
                                                        </DockPanel>

                                                        <!-- Subtle A2S corroboration status line. The roster is
                                                             primarily log-line driven; this line shows the live
                                                             cross-check against the running server's query port,
                                                             which evicts phantom rows when a disconnect line was
                                                             missed. Muted when healthy, warn-tinted when A2S has
                                                             stopped responding for two consecutive polls. Hidden
                                                             entirely until the first poll has produced a result. -->
                                                        <TextBlock DockPanel.Dock="Top" Margin="6,0,6,6"
                                                                   FontSize="11"
                                                                   Text="{Binding A2SVerifiedText}"
                                                                   Visibility="{Binding A2SVerifiedText, Converter={StaticResource StringToVisibility}}"
                                                                   ToolTip="A2S query confirms the live player count against the roster every 60 s. Mismatches are reconciled after two consecutive low readings.">
                                                            <TextBlock.Style>
                                                                <Style TargetType="{x:Type TextBlock}">
                                                                    <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                                                                    <Setter Property="VerticalAlignment" Value="Center" />
                                                                    <Setter Property="SnapsToDevicePixels" Value="True" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsA2SHealthy}" Value="False">
                                                                            <Setter Property="Foreground" Value="{StaticResource WarnBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <!-- Roster columns. ADDRESS removed (private/diagnostic, not
                                                             useful at a glance); PLATFORM widened so "PlayStation" /
                                                             "PC (Steam)" fit. PLATFORM binds to PlatformDisplay
                                                             (PC vs Console heuristic). Row template below MUST keep
                                                             the same column structure. -->
                                                        <Grid DockPanel.Dock="Top" Margin="6,2,6,6">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="80" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="150" />
                                                                <ColumnDefinition Width="120" />
                                                                <ColumnDefinition Width="90" />
                                                                <ColumnDefinition Width="120" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="STATUS" Style="{StaticResource MutedText}" FontSize="10" />
                                                            <TextBlock Grid.Column="1" Text="PLAYER" Style="{StaticResource MutedText}" FontSize="10" />
                                                            <TextBlock Grid.Column="2" Text="ID" Style="{StaticResource MutedText}" FontSize="10" />
                                                            <TextBlock Grid.Column="3" Text="PLATFORM" Style="{StaticResource MutedText}" FontSize="10" />
                                                            <TextBlock Grid.Column="4" Text="SESSION" Style="{StaticResource MutedText}" FontSize="10" />
                                                            <TextBlock Grid.Column="5" Text="LAST SEEN" Style="{StaticResource MutedText}" FontSize="10" />
                                                        </Grid>
                                                        <TextBlock DockPanel.Dock="Top" Style="{StaticResource MutedText}"
                                                                   Margin="6,4" TextWrapping="Wrap"
                                                                   Text="No players have connected yet. Start the server and have someone join."
                                                                   Visibility="{Binding HasItems, ElementName=RosterList, Converter={StaticResource InvBoolToVisibility}}" />
                                                        <ListBox x:Name="RosterList" ItemsSource="{Binding Roster}"
                                                                 ItemContainerStyle="{StaticResource RosterRowStyle}"
                                                                 SelectedItem="{Binding SelectedRosterPlayer, Mode=TwoWay}"
                                                                 Background="Transparent" BorderThickness="0"
                                                                 HorizontalContentAlignment="Stretch">
                                                            <ListBox.InputBindings>
                                                                <!-- Double-click a player -> open their detail tab. -->
                                                                <MouseBinding Gesture="LeftDoubleClick"
                                                                              Command="{Binding DataContext.ShowPlayerDetailCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                            </ListBox.InputBindings>
                                                            <ListBox.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Background="{StaticResource SurfaceBrush}"
                                                                            CornerRadius="4" Padding="10,6" Margin="0,0,0,4">
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="80" />
                                                                                <ColumnDefinition Width="*" />
                                                                                <ColumnDefinition Width="150" />
                                                                                <ColumnDefinition Width="120" />
                                                                                <ColumnDefinition Width="90" />
                                                                                <ColumnDefinition Width="120" />
                                                                            </Grid.ColumnDefinitions>
                                                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                                                <Ellipse Width="9" Height="9" Margin="0,0,6,0"
                                                                                         VerticalAlignment="Center"
                                                                                         Fill="{Binding IsOnline, Converter={StaticResource RunningToBrush}}" />
                                                                                <TextBlock Text="{Binding StatusText}" FontSize="11" />
                                                                            </StackPanel>
                                                                            <!-- Sec 3.3 admin thematic marker: warm gold name + superscript "+"
                                                                                 when the row's SteamID64 matches the moderator list. Tooltip
                                                                                 names the privilege. Decoration only - Ban/Unban operate on
                                                                                 the underlying captured id. -->
                                                                            <TextBlock Grid.Column="1" TextTrimming="CharacterEllipsis"
                                                                                       Foreground="{Binding IsAdmin, Converter={StaticResource IsAdminToBrush}}">
                                                                                <TextBlock.ToolTip>
                                                                                    <ToolTip Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibility}}"
                                                                                             Content="Server administrator - has admin commands." />
                                                                                </TextBlock.ToolTip>
                                                                                <Run Text="{Binding DisplayName, Mode=OneWay}" FontWeight="SemiBold" />
                                                                                <!-- Admin "+" marker. NO local Text="..." here:
                                                                                     WPF dependency-property precedence puts a local
                                                                                     value above style setters/triggers, so a hard
                                                                                     Text="+" would force the glyph on every row and
                                                                                     fight the IsAdmin DataTrigger below. The Style
                                                                                     setter starts empty and the trigger fills "+"
                                                                                     only when IsAdmin is true. -->
                                                                                <Run FontWeight="SemiBold"
                                                                                     Foreground="{StaticResource AdminAccentBrush}">
                                                                                    <Run.Style>
                                                                                        <Style TargetType="{x:Type Run}">
                                                                                            <Setter Property="Text" Value="" />
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding IsAdmin}" Value="True">
                                                                                                    <Setter Property="Text" Value=" +" />
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </Run.Style>
                                                                                </Run>
                                                                            </TextBlock>
                                                                            <TextBlock Grid.Column="2" Text="{Binding IdText}"
                                                                                       FontFamily="Consolas" FontSize="11"
                                                                                       Style="{StaticResource MutedText}"
                                                                                       TextTrimming="CharacterEllipsis" />
                                                                            <TextBlock Grid.Column="3" Text="{Binding PlatformDisplay}"
                                                                                       Style="{StaticResource MutedText}"
                                                                                       TextTrimming="CharacterEllipsis" />
                                                                            <TextBlock Grid.Column="4" Text="{Binding CurrentSessionText}" />
                                                                            <TextBlock Grid.Column="5" Text="{Binding LastSeenText}"
                                                                                       FontFamily="Consolas" FontSize="11"
                                                                                       Style="{StaticResource MutedText}" />
                                                                        </Grid>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ListBox.ItemTemplate>
                                                        </ListBox>
                                                    </DockPanel>
                                                </Border>
                                            </Grid>
                                        </TabItem>

                                        <!-- Player Detail: dynamically loaded when the admin
                                             double-clicks a roster row. Shows that player's
                                             lifecycle activity and the chat conversation. -->
                                        <TabItem Header="Player Detail">
                                            <Grid Margin="0,10,0,0">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>

                                                <Border Grid.Row="0" Background="{StaticResource SurfaceAltBrush}"
                                                        CornerRadius="4" Padding="12,10" Margin="0,0,0,10">
                                                    <TextBlock Text="{Binding PlayerDetailHeader}"
                                                               FontWeight="SemiBold" TextWrapping="Wrap" />
                                                </Border>

                                                <Border Grid.Row="1" Background="{StaticResource SurfaceAltBrush}"
                                                        CornerRadius="4" Padding="10,8" Margin="0,0,0,10"
                                                        Visibility="{Binding HasPlayerDetail, Converter={StaticResource BoolToVisibility}}">
                                                    <DockPanel>
                                                        <TextBlock DockPanel.Dock="Top" Text="Activity"
                                                                   FontWeight="SemiBold" Margin="0,0,0,6" />
                                                        <ListBox ItemsSource="{Binding SelectedPlayerActivity}"
                                                                 MaxHeight="150" Background="Transparent"
                                                                 BorderThickness="0" HorizontalContentAlignment="Stretch">
                                                            <ListBox.ItemTemplate>
                                                                <DataTemplate>
                                                                    <DockPanel Margin="0,0,0,2">
                                                                        <TextBlock DockPanel.Dock="Left"
                                                                                   Text="{Binding Timestamp, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"
                                                                                   FontFamily="Consolas"
                                                                                   Style="{StaticResource MutedText}"
                                                                                   Margin="0,0,10,0" />
                                                                        <TextBlock Text="{Binding KindText}"
                                                                                   TextTrimming="CharacterEllipsis" />
                                                                    </DockPanel>
                                                                </DataTemplate>
                                                            </ListBox.ItemTemplate>
                                                        </ListBox>
                                                    </DockPanel>
                                                </Border>

                                                <Border Grid.Row="2" Background="{StaticResource SurfaceAltBrush}"
                                                        CornerRadius="4" Padding="10,8"
                                                        Visibility="{Binding HasPlayerDetail, Converter={StaticResource BoolToVisibility}}">
                                                    <DockPanel>
                                                        <TextBlock DockPanel.Dock="Top" Text="Chat"
                                                                   FontWeight="SemiBold" Margin="0,0,0,2" />
                                                        <TextBlock DockPanel.Dock="Top" Style="{StaticResource MutedText}"
                                                                   FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"
                                                                   Text="The full conversation for context - this player's own messages are highlighted." />
                                                        <ListBox ItemsSource="{Binding SelectedPlayerChat}"
                                                                 Background="Transparent" BorderThickness="0"
                                                                 HorizontalContentAlignment="Stretch"
                                                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                                                            <ListBox.ItemTemplate>
                                                                <DataTemplate>
                                                                    <DockPanel Margin="0,0,0,3">
                                                                        <TextBlock DockPanel.Dock="Left"
                                                                                   Text="{Binding TimeText}"
                                                                                   FontFamily="Consolas"
                                                                                   Style="{StaticResource MutedText}"
                                                                                   Margin="0,0,10,0" />
                                                                        <TextBlock TextWrapping="Wrap">
                                                                            <Run Text="{Binding Name, Mode=OneWay}" FontWeight="SemiBold" />
                                                                            <Run Text=": " />
                                                                            <Run Text="{Binding Message, Mode=OneWay}" />
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="{x:Type TextBlock}">
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsFromPlayer}" Value="True">
                                                                                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                    </DockPanel>
                                                                </DataTemplate>
                                                            </ListBox.ItemTemplate>
                                                        </ListBox>
                                                    </DockPanel>
                                                </Border>
                                            </Grid>
                                        </TabItem>
                                    <TabItem Header="Admins">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                                            <StackPanel MaxWidth="640" HorizontalAlignment="Left">
                                                <TextBlock Text="Admin" Style="{StaticResource HeaderText}" />

                                                <TextBlock Text="Admin Password" Style="{StaticResource MutedText}"
                                                           Margin="0,8,0,0" />
                                                <Grid Margin="0,2,0,0">
                                                    <PasswordBox behaviors:PasswordBoxBehavior.IsAttached="True"
                                                                 behaviors:PasswordBoxBehavior.BoundPassword="{Binding AdminPassword, Mode=TwoWay}"
                                                                 Visibility="{Binding IsChecked, ElementName=RevealAdminPw2, Converter={StaticResource InverseBool}}" />
                                                    <TextBox Text="{Binding AdminPassword, UpdateSourceTrigger=PropertyChanged}"
                                                             Visibility="{Binding IsChecked, ElementName=RevealAdminPw2, Converter={StaticResource BoolToVisibility}}" />
                                                </Grid>
                                                <CheckBox x:Name="RevealAdminPw2" Content="Reveal" />
                                                <TextBlock Style="{StaticResource MutedText}" FontSize="11" Margin="0,2,0,12"
                                                           Text="Players who enter this password in-game gain admin commands." />

                                                <TextBlock Text="Admin.ini location" Style="{StaticResource MutedText}" />
                                                <DockPanel Margin="0,2,0,12" LastChildFill="True">
                                                    <Button DockPanel.Dock="Right" Content="Open Folder"
                                                            Margin="8,0,0,0"
                                                            Command="{Binding DataContext.OpenAdminFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                    <TextBox Text="{Binding AdminIniPath, UpdateSourceTrigger=PropertyChanged}" />
                                                </DockPanel>

                                                <TextBlock Text="Moderators (SteamID64)" Style="{StaticResource MutedText}" />
                                                <DockPanel Margin="0,2,0,8" LastChildFill="True">
                                                    <Button DockPanel.Dock="Right" Content="Add" Margin="8,0,0,0"
                                                            Style="{StaticResource AccentButton}"
                                                            Command="{Binding DataContext.AddAdminCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                    <TextBox Text="{Binding NewAdminId, UpdateSourceTrigger=PropertyChanged}" />
                                                </DockPanel>

                                                <TextBlock Text="{Binding AdminStatusText}"
                                                           Style="{StaticResource MutedText}" FontSize="11"
                                                           TextWrapping="Wrap" Margin="0,0,0,8" />

                                                <Border Background="{StaticResource SurfaceAltBrush}"
                                                        CornerRadius="4" Padding="6" MinHeight="80">
                                                    <ItemsControl ItemsSource="{Binding Admins}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Background="{StaticResource SurfaceBrush}"
                                                                        CornerRadius="4" Padding="10,6" Margin="0,0,0,4">
                                                                    <DockPanel LastChildFill="True">
                                                                        <Button DockPanel.Dock="Right" Content="Remove"
                                                                                Command="{Binding DataContext.RemoveAdminCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                CommandParameter="{Binding}" />
                                                                        <TextBlock Text="{Binding}" FontFamily="Consolas"
                                                                                   VerticalAlignment="Center"
                                                                                   Foreground="{StaticResource AdminAccentBrush}" />
                                                                    </DockPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Border>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </TabItem>

                                    <!-- Sec 3.2 Banished players sub-tab. Powered by the same sectioned
                                         Admin.ini reader as Ban/Unban; banned ids never appear in
                                         the live roster on Logs &amp; Status / Players. -->
                                    <TabItem Header="Banned">
                                        <Grid Margin="20">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Text="Banished Players"
                                                       Style="{StaticResource HeaderText}" />

                                            <TextBlock Grid.Row="1" Style="{StaticResource MutedText}"
                                                       Margin="0,0,0,12" TextWrapping="Wrap"
                                                       Text="Banned IDs read from this world's Admin.ini [BannedPlayers] section. The active roster on Logs &amp; Status excludes these IDs - unban here to bring them back." />

                                            <Border Grid.Row="2" Background="{StaticResource SurfaceAltBrush}"
                                                    CornerRadius="4" Padding="8">
                                                <DockPanel>
                                                    <Grid DockPanel.Dock="Top" Margin="6,0,6,6">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="150" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="120" />
                                                            <ColumnDefinition Width="80" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="90" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="ID" Style="{StaticResource MutedText}" FontSize="10" />
                                                        <TextBlock Grid.Column="1" Text="LAST-KNOWN NAME" Style="{StaticResource MutedText}" FontSize="10" />
                                                        <TextBlock Grid.Column="2" Text="DATE BANNED" Style="{StaticResource MutedText}" FontSize="10" />
                                                        <TextBlock Grid.Column="3" Text="SOURCE" Style="{StaticResource MutedText}" FontSize="10" />
                                                        <TextBlock Grid.Column="4" Text="NOTES" Style="{StaticResource MutedText}" FontSize="10" />
                                                        <TextBlock Grid.Column="5" Text="" Style="{StaticResource MutedText}" FontSize="10" />
                                                    </Grid>
                                                    <TextBlock DockPanel.Dock="Top" Style="{StaticResource MutedText}"
                                                               Margin="6,4" TextWrapping="Wrap"
                                                               Text="No banned players for this world."
                                                               Visibility="{Binding HasItems, ElementName=BannedList, Converter={StaticResource InvBoolToVisibility}}" />
                                                    <ListBox x:Name="BannedList" ItemsSource="{Binding BannedPlayers}"
                                                             Background="Transparent" BorderThickness="0"
                                                             HorizontalContentAlignment="Stretch">
                                                        <ListBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Background="{StaticResource SurfaceBrush}"
                                                                        CornerRadius="4" Padding="10,6" Margin="0,0,0,4">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="150" />
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="120" />
                                                                            <ColumnDefinition Width="80" />
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="90" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Grid.Column="0" Text="{Binding Id}"
                                                                                   FontFamily="Consolas" FontSize="11"
                                                                                   TextTrimming="CharacterEllipsis" />
                                                                        <TextBlock Grid.Column="1" Text="{Binding DisplayName}"
                                                                                   FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                                        <TextBlock Grid.Column="2" Text="{Binding DateBannedText}"
                                                                                   FontFamily="Consolas" FontSize="11"
                                                                                   Style="{StaticResource MutedText}" />
                                                                        <TextBlock Grid.Column="3" Text="{Binding SourceText}"
                                                                                   Style="{StaticResource MutedText}" />
                                                                        <TextBlock Grid.Column="4" Text="{Binding Notes}"
                                                                                   Style="{StaticResource MutedText}" />
                                                                        <Button Grid.Column="5" Content="Unban"
                                                                                Command="{Binding DataContext.UnbanFromBanishedCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                CommandParameter="{Binding Id}" />
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ListBox.ItemTemplate>
                                                    </ListBox>
                                                </DockPanel>
                                            </Border>
                                        </Grid>
                                    </TabItem>
                                    </TabControl>
                                </Grid>
                            </TabItem>

                            <!-- World / Player / Enemy / Advanced are now dynamic sub-tabs
                                 under the "Settings" tab above (one per discovered category).
                                 The uncategorised/unknown-key catch-all appears there as the
                                 "Advanced" category whenever it is non-empty. -->
                            </TabControl>
                        </Grid>
                    </Border>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>

        <!-- UI Tweaks A6 / F6: first-run clean slate. No world tabs until a world
             exists. The shared server is prepared first (Phase 1), then worlds. -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" CornerRadius="6"
                Visibility="{Binding HasWorlds, Converter={StaticResource InvBoolToVisibility}}">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="480">
                <!-- Phase 1: prepare the shared dedicated server first. -->
                <StackPanel Visibility="{Binding IsServerPrepared, Converter={StaticResource InvBoolToVisibility}}">
                    <TextBlock Text="First, prepare the server" FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource TextBrush}" />
                    <TextBlock Margin="0,10,0,0" TextWrapping="Wrap" TextAlignment="Center"
                               Style="{StaticResource MutedText}"
                               Text="Facility Overseer needs the Abiotic Factor dedicated server before you can create worlds. This downloads it (and SteamCMD) automatically - no Steam login required. One server install is shared by every world." />
                    <Button Content="Prepare / Update Server" Style="{StaticResource AccentButton}"
                            HorizontalAlignment="Center" Margin="0,20,0,0" Padding="22,9"
                            ToolTip="Download and install the Abiotic Factor dedicated server with SteamCMD."
                            Command="{Binding InstallOrUpdateServerCommand}" />
                </StackPanel>
                <!-- Phase 2: server ready - create the first world. -->
                <StackPanel Visibility="{Binding IsServerPrepared, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="Create your first world" FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource TextBrush}" />
                    <TextBlock Margin="0,10,0,0" TextWrapping="Wrap" TextAlignment="Center"
                               Style="{StaticResource MutedText}"
                               Text="The dedicated server is ready. Create a world to configure and launch it. Worlds are stored separately from the server, so they survive a server repair or reinstall." />
                    <Button Content="Create World" Style="{StaticResource AccentButton}"
                            HorizontalAlignment="Center" Margin="0,20,0,0" Padding="22,9"
                            ToolTip="Create a new managed world."
                            Command="{Binding CreateWorldCommand}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
