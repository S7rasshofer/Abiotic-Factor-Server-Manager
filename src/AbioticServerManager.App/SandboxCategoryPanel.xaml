<UserControl x:Class="AbioticServerManager.App.SandboxCategoryPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:AbioticServerManager.App.Views"
             xmlns:conv="clr-namespace:AbioticServerManager.App.Converters"
             x:Name="Root">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
        <conv:StringToVisibilityConverter x:Key="StrToVis" />

        <!-- Click anywhere on a row (other than its editor control) to open the
             setting's details in the side panel - there is no per-row "?" button. -->
        <Style x:Key="SettingRow" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <!-- Each template's DataContext is a SettingViewModel -->
        <DataTemplate x:Key="ToggleTpl">
            <Border Style="{StaticResource SettingRow}">
                <Border.InputBindings>
                    <MouseBinding Gesture="LeftClick"
                                  Command="{Binding DataContext.SelectCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                  CommandParameter="{Binding}" />
                </Border.InputBindings>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding DisplayName}" FontWeight="SemiBold" />
                    <ToggleButton Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                  IsChecked="{Binding BoolValue, Mode=TwoWay}"
                                  VerticalAlignment="Center" Margin="12,0" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="SliderTpl">
            <Border Style="{StaticResource SettingRow}">
                <Border.InputBindings>
                    <MouseBinding Gesture="LeftClick"
                                  Command="{Binding DataContext.SelectCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                  CommandParameter="{Binding}" />
                </Border.InputBindings>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="64" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding DisplayName}" FontWeight="SemiBold" />
                    <!-- Snap to the setting's metadata step so the track is not
                         hyper-sensitive and whole-number settings stay whole. -->
                    <Slider Grid.Column="1" VerticalAlignment="Center" Margin="12,0"
                            Minimum="{Binding Minimum}" Maximum="{Binding Maximum}"
                            Value="{Binding DoubleValue, Mode=TwoWay}"
                            IsSnapToTickEnabled="True"
                            TickFrequency="{Binding Step}"
                            SmallChange="{Binding Step}"
                            LargeChange="{Binding LargeStep}" />
                    <TextBox Grid.Column="2" Text="{Binding StringValue, UpdateSourceTrigger=LostFocus}"
                             VerticalAlignment="Center" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="NumberTpl">
            <Border Style="{StaticResource SettingRow}">
                <Border.InputBindings>
                    <MouseBinding Gesture="LeftClick"
                                  Command="{Binding DataContext.SelectCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                  CommandParameter="{Binding}" />
                </Border.InputBindings>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="160" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding DisplayName}" FontWeight="SemiBold" />
                    <TextBox Grid.Column="1" Margin="12,0"
                             Text="{Binding StringValue, UpdateSourceTrigger=LostFocus}" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="DropdownTpl">
            <Border Style="{StaticResource SettingRow}">
                <Border.InputBindings>
                    <MouseBinding Gesture="LeftClick"
                                  Command="{Binding DataContext.SelectCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                  CommandParameter="{Binding}" />
                </Border.InputBindings>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="200" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding DisplayName}" FontWeight="SemiBold" />
                    <ComboBox Grid.Column="1" Margin="12,0"
                              ItemsSource="{Binding OptionItems}"
                              DisplayMemberPath="Label"
                              SelectedValuePath="Value"
                              SelectedValue="{Binding SelectedOption, Mode=TwoWay}" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="TextTpl">
            <Border Style="{StaticResource SettingRow}">
                <Border.InputBindings>
                    <MouseBinding Gesture="LeftClick"
                                  Command="{Binding DataContext.SelectCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                  CommandParameter="{Binding}" />
                </Border.InputBindings>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="240" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding DisplayName}" FontWeight="SemiBold" />
                    <TextBox Grid.Column="1" Margin="12,0"
                             Text="{Binding StringValue, UpdateSourceTrigger=LostFocus}" />
                </Grid>
            </Border>
        </DataTemplate>

        <views:SettingTemplateSelector x:Key="Selector"
            ToggleTemplate="{StaticResource ToggleTpl}"
            SliderTemplate="{StaticResource SliderTpl}"
            NumberTemplate="{StaticResource NumberTpl}"
            DropdownTemplate="{StaticResource DropdownTpl}"
            TextTemplate="{StaticResource TextTpl}" />
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal"
                    HorizontalAlignment="Left" Margin="0,0,0,10"
                    Visibility="{Binding IsLoaded, Converter={StaticResource BoolToVis}}">
            <Button Content="Tab Defaults"
                    ToolTip="Reset every setting on this tab to its built-in default value."
                    Command="{Binding ResetBucketCommand}"
                    CommandParameter="{Binding ItemsSource, ElementName=Root}" />
            <Button Content="Revert from file"
                    ToolTip="Discard unsaved changes and reload every setting from the saved SandboxSettings.ini on disk."
                    Command="{Binding RevertFromFileCommand}" />
        </StackPanel>

        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Top"
                   Style="{StaticResource MutedText}" MaxWidth="520" HorizontalAlignment="Left"
                   Text="{Binding EmptyHint, ElementName=Root}"
                   Visibility="{Binding IsLoaded, Converter={StaticResource InvBoolToVis}}" />

        <ScrollViewer Grid.Row="1" Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,12,0"
                      Visibility="{Binding IsLoaded, Converter={StaticResource BoolToVis}}">
            <ItemsControl ItemsSource="{Binding ItemsSource, ElementName=Root}"
                          ItemTemplateSelector="{StaticResource Selector}" />
        </ScrollViewer>

        <!-- Details panel - populated by clicking a setting row. -->
        <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                Background="{StaticResource SurfaceAltBrush}"
                CornerRadius="6" Padding="14">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                    <TextBlock Style="{StaticResource MutedText}" VerticalAlignment="Top"
                               Text="Click a setting to see its details."
                               Visibility="{Binding SelectedSetting, Converter={StaticResource NullToVis}, ConverterParameter=invert}" />

                    <StackPanel DataContext="{Binding SelectedSetting}"
                                Visibility="{Binding DataContext.SelectedSetting, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Converter={StaticResource NullToVis}}">
                        <TextBlock Text="SETTING DETAILS" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}" Margin="0,0,0,10" />
                        <TextBlock Text="{Binding DisplayName}" FontSize="16" FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding SourceText}" Style="{StaticResource MutedText}"
                                   FontStyle="Italic" Margin="0,2,0,12" />

                        <TextBlock Text="Description" Style="{StaticResource MutedText}" FontSize="11" />
                        <TextBlock Text="{Binding Description, FallbackValue='No description available.', TargetNullValue='No description available.'}"
                                   TextWrapping="Wrap" Margin="0,0,0,12" />

                        <TextBlock Text="Internal key" Style="{StaticResource MutedText}" FontSize="11" />
                        <TextBlock Text="{Binding Key}" Margin="0,0,0,8" TextWrapping="Wrap" />

                        <TextBlock Text="Current value" Style="{StaticResource MutedText}" FontSize="11" />
                        <TextBlock Text="{Binding CurrentValueDisplay}" Margin="0,0,0,8" TextWrapping="Wrap" />

                        <TextBlock Text="Default" Style="{StaticResource MutedText}" FontSize="11" />
                        <TextBlock Text="{Binding DefaultValue, FallbackValue='-', TargetNullValue='-'}"
                                   Margin="0,0,0,8" />

                        <TextBlock Text="Range" Style="{StaticResource MutedText}" FontSize="11" />
                        <TextBlock Text="{Binding RangeText}" Margin="0,0,0,8" />

                        <TextBlock Text="Options" Style="{StaticResource MutedText}" FontSize="11" />
                        <TextBlock Text="{Binding OptionsText}" Margin="0,0,0,8" TextWrapping="Wrap" />

                        <Border Background="{StaticResource WarningTintBrush}" CornerRadius="4" Padding="8" Margin="0,4,0,8"
                                Visibility="{Binding Warning, Converter={StaticResource StrToVis}}">
                            <TextBlock Text="{Binding Warning}" TextWrapping="Wrap"
                                       Foreground="{StaticResource WarnBrush}" />
                        </Border>

                        <Border Background="{StaticResource InfoTintBrush}" CornerRadius="4" Padding="8" Margin="0,4,0,0"
                                Visibility="{Binding UnknownNotice, Converter={StaticResource StrToVis}}">
                            <TextBlock Text="{Binding UnknownNotice}" TextWrapping="Wrap"
                                       Style="{StaticResource MutedText}" />
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
