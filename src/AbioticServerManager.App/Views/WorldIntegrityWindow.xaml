<Window x:Class="AbioticServerManager.App.Views.WorldIntegrityWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:AbioticServerManager.App.Converters"
        Title="World integrity"
        Width="520" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        FontFamily="Segoe UI" FontSize="13"
        Background="{StaticResource SurfaceBrush}"
        Foreground="#E6ECF2">
    <Window.Resources>
        <!-- Converters live in MainWindow.Resources, not at app scope, so the
             popup needs its own instances. Cheap stateless objects. -->
        <conv:IntegritySeverityToBrushConverter x:Key="IntegritySeverityToBrush" />
        <conv:StringToVisibilityConverter x:Key="StringToVisibility" />
    </Window.Resources>
    <Border Padding="16" MaxHeight="520">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top" Text="{Binding IntegritySummary}"
                       FontSize="16" FontWeight="Bold" Margin="0,0,0,10"
                       TextWrapping="Wrap" />
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding IntegrityFindings}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource SurfaceAltBrush}"
                                    CornerRadius="4" Margin="0,0,0,6">
                                <Expander Padding="10,4">
                                    <Expander.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="9" Height="9" Margin="0,0,8,0"
                                                     VerticalAlignment="Center"
                                                     Fill="{Binding Severity, Converter={StaticResource IntegritySeverityToBrush}}" />
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                                       VerticalAlignment="Center" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Expander.Header>
                                    <StackPanel Margin="17,4,0,6">
                                        <TextBlock Text="{Binding Detail}"
                                                   Style="{StaticResource MutedText}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding SuggestedFix}"
                                                   Style="{StaticResource MutedText}"
                                                   TextWrapping="Wrap" FontStyle="Italic"
                                                   Margin="0,4,0,0"
                                                   Visibility="{Binding SuggestedFix, Converter={StaticResource StringToVisibility}}" />
                                        <Button Content="{Binding ActionLabel}"
                                                Margin="0,8,0,0" HorizontalAlignment="Left"
                                                Padding="12,5"
                                                Visibility="{Binding CommandHint, Converter={StaticResource StringToVisibility}}"
                                                Command="{Binding Owner.DataContext.RunIntegrityActionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>
                                </Expander>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
