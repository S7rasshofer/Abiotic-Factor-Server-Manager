<Window x:Class="AbioticServerManager.App.Views.RecommendedActionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:AbioticServerManager.App.Converters"
        Title="Recommended next steps"
        Width="520" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        FontFamily="Segoe UI" FontSize="13"
        Background="{StaticResource SurfaceBrush}"
        Foreground="#E6ECF2">
    <Window.Resources>
        <!-- Converters live in MainWindow.Resources, not at app scope, so the
             popup needs its own instances. Cheap stateless objects. -->
        <conv:RecommendedPriorityToBrushConverter x:Key="RecommendedPriorityToBrush" />
        <conv:StringToVisibilityConverter x:Key="StringToVisibility" />
    </Window.Resources>
    <Border Padding="16" MaxHeight="520">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top" Text="Recommended next steps"
                       FontSize="16" FontWeight="Bold" Margin="0,0,0,10" />
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding RecommendedActions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource SurfaceAltBrush}"
                                    CornerRadius="4" Padding="10,8" Margin="0,0,0,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Grid.Column="0" Width="9" Height="9"
                                             Margin="0,4,8,0" VerticalAlignment="Top"
                                             Fill="{Binding Priority, Converter={StaticResource RecommendedPriorityToBrush}}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Title}"
                                                   FontWeight="SemiBold" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding Detail}"
                                                   Style="{StaticResource MutedText}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Button Grid.Column="2" Content="Do this"
                                            Margin="8,0,0,0" VerticalAlignment="Top"
                                            Visibility="{Binding CommandHint, Converter={StaticResource StringToVisibility}}"
                                            Command="{Binding Owner.DataContext.RunRecommendedActionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
