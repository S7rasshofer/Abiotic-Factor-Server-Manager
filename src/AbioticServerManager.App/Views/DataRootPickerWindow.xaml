<Window x:Class="AbioticServerManager.App.Views.DataRootPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Facility Overseer - Where should we keep your data?"
        Width="640" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontFamily="Segoe UI" FontSize="13"
        Background="#0E1218" Foreground="#E6ECF2">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Choose a data folder"
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,4" />
        <TextBlock Grid.Row="1" TextWrapping="Wrap" Margin="0,0,0,16"
                   Foreground="#A8B5C1"
                   Text="Where Facility Overseer keeps everything - worlds, settings, backups, and the game server. Hover a choice to see its full path." />

        <StackPanel Grid.Row="2">
            <!-- Option 1: data folder beside the application. Full path on hover. -->
            <RadioButton x:Name="PortableRadio" GroupName="DataRoot" Margin="0,0,0,12"
                         Content="In the Facility Overseer folder"
                         ToolTip="{Binding PortablePath}" />

            <!-- Option 2: a custom folder. The path box stays hidden until chosen. -->
            <RadioButton x:Name="CustomRadio" GroupName="DataRoot"
                         Content="Custom folder"
                         ToolTip="Pick any folder - for example one on a flash drive." />
            <DockPanel Margin="22,6,0,0" LastChildFill="True">
                <DockPanel.Style>
                    <Style TargetType="DockPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsChecked, ElementName=CustomRadio}"
                                         Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DockPanel.Style>
                <Button DockPanel.Dock="Right" Content="Browse..." Margin="6,0,0,0"
                        Click="OnBrowseClicked" />
                <TextBox x:Name="CustomPathBox" />
            </DockPanel>
        </StackPanel>

        <TextBlock Grid.Row="3" Margin="0,18,0,12" TextWrapping="Wrap"
                   Foreground="#E6B84B" FontSize="11"
                   Text="Tip: pick a custom folder - even one on a flash drive - to keep the whole program portable. You can open these folders later from buttons inside the app, and this dialog won't appear again unless you reset the saved choice." />

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Padding="14,5" Margin="0,0,8,0" Click="OnCancelClicked" />
            <Button Content="Continue" Padding="14,5" IsDefault="True"
                    Click="OnContinueClicked" />
        </StackPanel>
    </Grid>
</Window>
