<Window x:Class="AbioticServerManager.App.Views.LegacyDataImportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Facility Overseer - Previous data found"
        Width="640" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontFamily="Segoe UI" FontSize="13"
        Background="#0E1218" Foreground="#E6ECF2">
    <StackPanel Margin="20">
        <TextBlock Text="Previous Facility Overseer data was found"
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,4" />
        <TextBlock TextWrapping="Wrap" Margin="0,0,0,16" Foreground="#A8B5C1"
                   Text="We can import your old world profiles into this fresh data folder, or you can start completely fresh. Your old folders are never moved or deleted either way." />

        <Border BorderBrush="#2A3340" BorderThickness="1" Padding="10"
                Margin="0,0,0,14" CornerRadius="3">
            <ItemsControl x:Name="FindingsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="{Binding Root}" FontFamily="Consolas"
                                       FontSize="12" Foreground="#E6B84B"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding WorldsLine}" FontSize="12"
                                       Foreground="#A8B5C1"
                                       TextWrapping="Wrap" Margin="0,2,0,0" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <TextBlock TextWrapping="Wrap" Margin="0,0,0,4" Foreground="#A8B5C1"
                   FontSize="11">
            <Run Text="On import, paths that no longer exist on disk (old install folders, old sandbox files) are reset to the new data root so everything resolves cleanly." />
        </TextBlock>
        <TextBlock TextWrapping="Wrap" Margin="0,0,0,18" Foreground="#A8B5C1"
                   FontSize="11">
            <Run Text="Start fresh records your choice so this prompt will not appear again." />
        </TextBlock>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Start fresh" Padding="14,5" Margin="0,0,8,0"
                    Click="OnStartFreshClicked" />
            <Button Content="Import these worlds" Padding="14,5" IsDefault="True"
                    Click="OnImportClicked" />
        </StackPanel>
    </StackPanel>
</Window>
